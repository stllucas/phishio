{
    "manifest_version": 3,
    "name": "Phishio",
    "description": "Detecção Colaborativa de Phishing em Tempo Real via Abordagem Híbrida.",
    "version": "1.0.0",

    "background": {
        "service_worker": "background.js"
    },

    "permissions": [
        "storage",
        "tabs",
        "scripting",
        "notifications"
    ],

    "host_permissions": [
        "<all_urls>"
    ],

    "action": {
        "default_popup": "popup.html",
        "default_title": "Phishio",
        "default_icon": {
            "16": "icons/logo-16.png",
            "32": "icons/logo-32.png",
            "48": "icons/logo-48.png"
        }
    },

    "icons": {
        "16": "icons/shield-inactive-16.png",
        "32": "icons/shield-inactive-32.png",
        "48": "icons/shield-inactive-48.png",
        "128": "icons/shield-inactive-128.png"
    }
}
