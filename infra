terraform {
  required_providers {
    google = {
      source  = "hashicorp/google"
      version = "~> 4.0"
    }
  }
}

provider "google" {
  project = var.gcp_project_id
  region  = "us-central1"
  zone    = "us-central1-a"
}

variable "gcp_project_id" {
  description = "The ID of the GCP Project"
  type        = string
}

# Enable Firestore (Native Mode)
resource "google_app_engine_application" "firestore_app" {
  project       = var.gcp_project_id
  location_id   = "us-central"
  database_type = "CLOUD_FIRESTORE"
}

# Google Compute Engine Instance for the FastAPI Backend
resource "google_compute_instance" "phishio_api" {
  name         = "phishio-backend-api"
  machine_type = "e2-micro" # Fits within GCP Free Tier

  boot_disk {
    initialize_params {
      image = "debian-cloud/debian-11"
    }
  }

  network_interface {
    network = "default"
    access_config {
      # Ephemeral public IP
    }
  }

  tags = ["http-server", "https-server"]

  # Startup script to pull and run the Docker container
  metadata_startup_script = "sudo apt-get update && sudo apt-get install -y docker.io && sudo docker run -d -p 80:8000 ghcr.io/youruser/phishio-api:latest"
}